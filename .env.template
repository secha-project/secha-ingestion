# Copy to .env and fill in. .env is gitignored; never commit secrets.

# Storage (local now; later e.g. s3://secha-raw or abfs://container@account.dfs.core.windows.net/raw)
SECHA_LANDING_ROOT=data/landing

# HTTP resilience (NOT transformation)
SECHA_REQUEST_TIMEOUT_S=20
SECHA_MAX_RETRIES=3

# MX Electrix connector
SECHA_ELECTRIX_HOST_URL=
SECHA_ELECTRIX_ACCESS_TOKEN=
SECHA_ELECTRIX_ALLOW_INVALID_CERTS=false
# Leave unset to request the server default (all fields). Open question.
# SECHA_ELECTRIX_FIELDS=
